# Development overrides — use with:
# docker compose -f docker-compose.yml -f docker-compose.dev.yml up

services:
  web:
    build:
      context: ../web
      dockerfile: ../infra/dockerfiles/Dockerfile.web
      target: dev
    volumes:
      - ../web:/app
      - /app/node_modules
      - /app/.next
    environment:
      - NODE_ENV=development
      - NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
      - NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/chat/stream

  api:
    volumes:
      - ../api:/app
    environment:
      - ENVIRONMENT=development
      - DEBUG=true
    command: uvicorn main:app --host 0.0.0.0 --port 8000 --reload

  celery_worker:
    volumes:
      - ../api:/app
    environment:
      - ENVIRONMENT=development

  celery_beat:
    volumes:
      - ../api:/app
    environment:
      - ENVIRONMENT=development

  postgres:
    ports:
      - "5432:5432"

  redis:
    ports:
      - "6379:6379"

  falkordb:
    ports:
      - "6380:6379"

  graphiti:
    ports:
      - "8001:8001"

  n8n:
    ports:
      - "5678:5678"
